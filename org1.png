export interface CaseStudy {
  id: string;
  title: string;
  subtitle: string;
  problemStatement: string;
  impact: string[];
  role: string;
  timeline: string;
  thumbnail: string;
  category?: 'flagship' | 'featured' | 'additional';
  signalBar?: {
    scope: string;
    users: string;
  };
  scannableSummary?: {
    impact: string[];
    problem: string;
    whyItMatters: string;
    keyDecisions: string[];
  };
  overview: {
    context: string;
    challenge: string;
    solution: string;
  };
  details: {
    problem: string;
    roleResponsibilities: string[];
    constraints: string[];
    research: string[];
    designProcess: string[];
    keyDesignDecisions?: string[];
    leadershipInfluence?: string[];
    beforeAfter?: string[];
    finalSolution: string;
    impact: string[];
    learnings: string[];
  };
}

